# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# reCAPTCHA v3
# テスト用キー (Google 提供): フォーム送信は常にスコア 1.0 で通る
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
# RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# Resend（問い合わせメール送信）
# 未設定時はメール送信をスキップしてコンソールログのみ
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Contact
CONTACT_EMAIL=your-email@example.com

# スキルシート自動同期（scripts/sync-skill-sheet）
# 大本スプレッドシートの ID。実 ID はコミットしない（.env.local に設定）
SKILL_SHEET_SPREADSHEET_ID=
# Service Account 認証。JSON 文字列（Routine 用）か鍵ファイルパス（ローカル用）のどちらか
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SERVICE_ACCOUNT_FILE=./scripts/sync-skill-sheet/.secrets/sa.json
